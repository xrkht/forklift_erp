# Image imported into Synology Container Manager or pulled from a registry.
ERP_IMAGE=forklift-erp
ERP_VERSION=20260713-001
ERP_HTTP_PORT=8080
TZ=Asia/Shanghai

# Replace every example secret before the first start.
MYSQL_ROOT_PASSWORD=replace-with-a-long-random-root-password
ERP_DB_PASSWORD=replace-with-a-long-random-database-password
ERP_JWT_SECRET=replace-with-at-least-32-bytes-of-random-text
ERP_JWT_EXPIRATION=86400000
ERP_ADMIN_USERNAME=admin
ERP_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
