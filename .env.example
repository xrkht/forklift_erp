# Copy this file to .env for local runs, or export the same variables in CI.
# Spring Boot imports .env automatically via spring.config.import.
# Windows users can run Maven with .\scripts\mvnw-jdk21.cmd verify.

JAVA_HOME=C:/Program Files/Eclipse Adoptium/jdk-21

FORKLIFT_ERP_SERVER_PORT=8080
FORKLIFT_ERP_HTTP_PORT=8080
FORKLIFT_ERP_SSL_ENABLED=false

FORKLIFT_ERP_DB_URL=jdbc:mysql://localhost:3306/forklift_erp?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
FORKLIFT_ERP_DB_USERNAME=forklift_erp
FORKLIFT_ERP_DB_PASSWORD=change-me

# Use at least 32 bytes of random text.
FORKLIFT_ERP_JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes
FORKLIFT_ERP_JWT_EXPIRATION=31536000000

# Disabled by default. Enable only for first-time local bootstrapping.
FORKLIFT_ERP_BOOTSTRAP_ADMIN_ENABLED=false
FORKLIFT_ERP_BOOTSTRAP_ADMIN_USERNAME=admin
FORKLIFT_ERP_BOOTSTRAP_ADMIN_PASSWORD=change-me-before-enabling

FORKLIFT_ERP_SEED_DEMO_DATA=false
FORKLIFT_ERP_INVOICE_STORAGE_DIR=uploads/invoices
FORKLIFT_ERP_CONTRACT_STORAGE_DIR=uploads/contracts

# Tests use Testcontainers by default. Override these only when intentionally
# pointing tests at a manually managed database.
FORKLIFT_ERP_TEST_DB_URL=jdbc:tc:mysql:8.4.0:///forklift_erp_test?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
FORKLIFT_ERP_TEST_DB_USERNAME=test
FORKLIFT_ERP_TEST_DB_PASSWORD=test
FORKLIFT_ERP_TEST_DB_DRIVER=org.testcontainers.jdbc.ContainerDatabaseDriver
FORKLIFT_ERP_TEST_JWT_SECRET=replace-with-a-random-test-secret-32-bytes
